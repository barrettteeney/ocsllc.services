{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":   ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["warn", { "minScore": 0.90 }],
        "categories:best-practices":["warn", { "minScore": 0.90 }],
        "categories:seo":           ["error",{ "minScore": 0.95 }]
      }
    }
  }
}
